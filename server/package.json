{
  "name": "teem-commerce-server",
  "version": "1.0.0",
  "main": "index.js",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "build": "rm -rf dist && tsc",
    "start": "node dist/api/index.js",
    "dev": "NODE_ENV=development tsx watch api/index.ts",
    "dev:staging": "NODE_ENV=staging tsx watch api/index.ts",
    "lint": "eslint . --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "qstash": "npx @upstash/qstash-cli@latest dev",
    "ngrok": "ngrok http --url=salmon-daring-partially.ngrok-free.app 5600",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:payment": "vitest run src/routes/payment.routes.test.ts src/routes/paystack.routes.test.ts"
  },
  "dependencies": {
    "@sentry/node": "^10.45.0",
    "@ts-rest/core": "^3.52.1",
    "@ts-rest/express": "^3.52.1",
    "@upstash/ratelimit": "^2.0.8",
    "@upstash/redis": "^1.36.0",
    "@upstash/workflow": "^1.1.0",
    "axios": "^1.13.2",
    "better-auth": "^1.4.3",
    "cloudinary": "^2.7.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^4.1.0",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "mongoose": "^9.0.0",
    "morgan": "^1.10.1",
    "resend": "^6.9.1",
    "winston": "^3.18.3",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.19",
    "@types/morgan": "^1.9.10",
    "@types/node": "^24.10.1",
    "@types/supertest": "^7.2.0",
    "@vitest/ui": "^4.0.18",
    "dotenv": "^17.3.1",
    "esbuild": "^0.27.3",
    "supertest": "^7.2.2",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "tsx": "^4.19.2",
    "typescript": "^5.9.3",
    "vite": "7.3.1",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "4.1.4"
  },
  "resolutions": {
    "vite": "7.3.1"
  }
}
